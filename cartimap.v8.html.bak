        const t = getParsedTags(d.tags);
        t.forEach(tag => tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1));
        for (let i = 0; i < t.length - 1; i++) {
            for (let j = i + 1; j < t.length; j++) {
                const pair = [t.at(i), t.at(j)].sort().join('|');
                tagPairs.set(pair, (tagPairs.get(pair) || 0) + 1);
            }
        }
    });

    let orderedTags = []; const remaining = Array.from(tagsMap.keys()).sort((a, b) => tagsMap.get(b) - tagsMap.get(a));
    if (remaining.length > 0) { orderedTags.push(remaining.at(0)); remaining.splice(0, 1); }

    while (remaining.length > 0) {
        let bestMatchIdx = 0; let bestScore = -1; let insertPos = 'push';
        for (let i = 0; i < remaining.length; i++) {
            const r = remaining.at(i);
            const firstTag = orderedTags.at(0); const lastTag = orderedTags.at(-1);
            const scoreWithFirst = tagPairs.get([r, firstTag].sort().join('|')) || 0;
            const scoreWithLast = tagPairs.get([r, lastTag].sort().join('|')) || 0;
            const baseFreq = tagsMap.get(r) || 0;
            
            const totalScoreFirst = (scoreWithFirst * 1000) + baseFreq;
            const totalScoreLast = (scoreWithLast * 1000) + baseFreq;

            if (totalScoreLast > bestScore) { bestScore = totalScoreLast; bestMatchIdx = i; insertPos = 'push'; }
            if (totalScoreFirst > bestScore) { bestScore = totalScoreFirst; bestMatchIdx = i; insertPos = 'unshift'; }
        }
        if (insertPos === 'push') { orderedTags.push(remaining.at(bestMatchIdx)); remaining.splice(bestMatchIdx, 1); }
        else { orderedTags.unshift(remaining.at(bestMatchIdx)); remaining.splice(bestMatchIdx, 1); }
