            if (wrapperRef.current) ro.observe(wrapperRef.current);
            return () => ro.disconnect();
          }, []);

          const getParsedTags = (rawTagsArray) => {
            if (!rawTagsArray || rawTagsArray.length === 0) return ['Untagged'];
            const splitRegex = /[\r\n]+|\\n/;
            let arr = [];
            rawTagsArray.forEach(t => {
              if (typeof t === 'string') arr.push(...t.split(splitRegex));
              else arr.push(t);
            });
            arr = arr.map(s => String(s).trim()).filter(Boolean);
            return arr.length > 0 ? arr : ['Untagged'];
          };

          const tagsMap = new Set();
          const tagPairs = [];
          data.forEach(d => {
            if (!d.startDate || isNaN(d.startDate.min)) return;
            const t = getParsedTags(d.tags);
            t.forEach(tag => tagsMap.add(tag));
            for (let i = 0; i < t.length - 1; i++) tagPairs.push([t.at(i), t.at(i + 1)]);
          });

          let orderedTags = [];
          const remaining = Array.from(tagsMap);
          if (remaining.length > 0) orderedTags.push(remaining.shift());
          
          while (remaining.length > 0) {
            let placed = false;
            for (let i = 0; i < remaining.length; i++) {
              const r = remaining.at(i);
              const firstTag = orderedTags.at(0);
              const lastTag = orderedTags.at(-1);
              const pairedWithFirst = tagPairs.some(p => (p.at(0) === r && p.at(1) === firstTag) || (p.at(1) === r && p.at(0) === firstTag));
              const pairedWithLast = tagPairs.some(p => (p.at(0) === r && p.at(1) === lastTag) || (p.at(1) === r && p.at(0) === lastTag));
              
              if (pairedWithLast) {
                orderedTags.push(r);
                remaining.splice(i, 1);
                placed = true;
                break;
              }
              if (pairedWithFirst) {
                orderedTags.unshift(r);
                remaining.splice(i, 1);
                placed = true;
                break;
              }
            }
            if (!placed) orderedTags.push(remaining.shift());
          }

          const laneCount = Math.max(1, orderedTags.length);
          const laneHeight = Math.max(24, (containerHeight - 38) / laneCount);
          const validData = data.filter(d => d.startDate && !isNaN(d.startDate.min));
          const minTimeRaw = validData.length > 0 ? validData.at(0).startDate.min : new Date().getTime();
          let maxTimeRaw = minTimeRaw;
          
          validData.forEach(d => {
            if (d.endDate && !isNaN(d.endDate.max) && d.endDate.max > maxTimeRaw) {
              maxTimeRaw = d.endDate.max;
            } else if (d.startDate.min > maxTimeRaw) {
              maxTimeRaw = d.startDate.min;
            }
          });

          const rawTimeRange = Math.max(maxTimeRaw - minTimeRaw, 86400000);
          const padMs = rawTimeRange * 0.05;
          const renderMinTime = minTimeRaw - padMs;
          const renderMaxTime = maxTimeRaw + padMs;
          const renderTimeRange = renderMaxTime - renderMinTime;

