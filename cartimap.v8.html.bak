            const itemStart = item.startDate.min;
            const itemEnd = item.endDate && !isNaN(item.endDate.max) ? item.endDate.max : itemStart;
            const overlaps = validData.filter(d => {
                if (d.id === item.id) return false;
                const dStart = d.startDate.min;
