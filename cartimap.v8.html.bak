                        </div>

                        <div style="flex-grow: 1; padding: 0.5rem 1.5rem 2rem 1.5rem; display: flex; justify-content: center; width: 100%; box-sizing: border-box;">
                            <div class="slide-desc" style="max-width: 65ch; width: 100%; margin: 0 auto;" dangerouslySetInnerHTML=${{"__html": slide.description}}></div>
                        </div>
                    </div>
                </div>
            `;
