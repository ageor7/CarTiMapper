        const globalIndex = data.findIndex(d => d.id === item.id);
        const startPct = Number((((itemStartMs - renderMinTime) / renderTimeRange) * 100).toFixed(4));
        const tagIndices = getParsedTags(item.tags).map(t => orderedTags.indexOf(t)).filter(idx => idx !== -1);
