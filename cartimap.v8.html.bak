        // === [ MAJOR BLOCK: ContentSlider v4.4.1 ] ===
        const ContentSlider = ({data, activeIndex, setActiveIndex, maxPane, setMaxPane, dateLocale, formatSmartDate}) => {
            const touchStartX = useRef (0);
            const [isScrolled, setIsScrolled] = useState (false);

            const slide = data [activeIndex];
            if (!slide) return null;

            const getParsedTags = (rawTagsArray) => {
                if (!rawTagsArray || rawTagsArray.length === 0) return [];
                const splitRegex = /[\r\n]+|\\n/; let arr = [];
                (Array.isArray (rawTagsArray) ? rawTagsArray : [rawTagsArray]).forEach (t => { if (typeof t === 'string') arr.push (...t.split (splitRegex)); else arr.push (t); });
                return arr.map (s => String (s).trim ()).filter (Boolean);
            };

            const formatPlaces = (str) => { return str ? str.split (/[|\-·;]/).map (s => s.split (',')[0].trim ()).filter (Boolean).join (' | ') : ''; };

            const tags = getParsedTags (slide.tags); const hasLocation = slide.place && String (slide.place).trim () !== '';
            const goPrev = () => { if (activeIndex > 0) setActiveIndex (activeIndex - 1); };
            const goNext = () => { if (activeIndex < data.length - 1) setActiveIndex (activeIndex + 1); };

            const handleTouchStart = (e) => { touchStartX.current = e.changedTouches [0].screenX; };
            const handleTouchEnd = (e) => { const x = e.changedTouches [0].screenX; if (touchStartX.current - x > 50) goNext (); if (x - touchStartX.current > 50) goPrev (); };
            const handleScroll = (e) => { const s = e.target.scrollTop; if (s > 40 && !isScrolled) setIsScrolled (true); else if (s <= 40 && isScrolled) setIsScrolled (false); };

            return html`
                <div class="content-pane-wrapper" style="display: flex; flex-direction: column; height: 100%; position: relative; width: 100%;">

                    <div style="position: absolute; top: 15px; right: 15px; z-index: 1000;">
                        <button class="status-btn ${maxPane === 'text' ? 'active' : ''}" style="background: rgba(255,255,255,0.9); border: 1px solid #ccc; box-shadow: 0 2px 5px rgba(0,0,0,0.1);" onClick=${() => setMaxPane (maxPane === 'text' ? null : 'text')} title="Toggle Maximize">
                            ${maxPane === 'text'
                                ? html`<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/></svg>`
                                : html`<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>`
                            }
                        </button>
                    </div>

                    <div class="content-scroll-area" onTouchStart=${handleTouchStart} onTouchEnd=${handleTouchEnd} onScroll=${handleScroll}>
                        <div class="click-zone click-zone-left" onClick=${goPrev} title="Previous"></div>
                        <div class="click-zone click-zone-right" onClick=${goNext} title="Next"></div>

                        <div style="flex-shrink: 0; position: sticky; top: 0; background: var(--paneBg, #ffffff); z-index: 10; padding-top: ${isScrolled ? '0.6rem' : '1.2rem'}; padding-bottom: ${isScrolled ? '0.4rem' : '0.5rem'}; border-bottom: 1px solid rgba(128,128,128,0.2); box-shadow: ${isScrolled ? '0 4px 12px rgba(0,0,0,0.06)' : '0 2px 8px rgba(0,0,0,0.04)'}; display: flex; flex-direction: column; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); width: 100%; padding-left: 1.5rem; padding-right: 55px; box-sizing: border-box;">
                            
                            <div style="max-width: 85ch; width: 100%; margin: 0 auto; display: flex; flex-direction: column;">
                                
                                <div class="metadata-ribbon" style="width: 100%; padding: 0; margin-bottom: 0.4rem; box-sizing: border-box;">
                                    <div class="metadata-date">${formatSmartDate (slide.startDate, slide.endDate, dateLocale)}</div>
                                    <div class="metadata-pills-wrapper">
                                        ${hasLocation ? html`<span class="place-pill"><span style="margin-right: 4px;">📍</span> ${formatPlaces (slide.place)}</span>` : ''}
                                        ${tags.map (tag => html`<span class="tag-pill"><svg width="10" height="10" viewBox="0 0 24 24" fill="rgba(255, 193, 7, 0.2)" stroke="#ffc107" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px; flex-shrink: 0;"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg><span>${tag}</span></span>`)}
                                    </div>
                                </div>

                                <div class="title-header-container" style="width: 100%; padding: 0; box-sizing: border-box;">
                                    <h2 style="margin: 0; font-size: ${isScrolled ? '1.1rem' : '1.4rem'}; line-height: 1.2; transition: font-size 0.3s ease; color: #222;" dangerouslySetInnerHTML=${{"__html": slide.title}}></h2>
                                </div>

