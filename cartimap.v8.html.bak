    const centerTickPx = centerTickIndex !== -1 ? (majorTicksData.at(centerTickIndex).pctLeft / 100) * trackWidthPx : -1000;
    const centerKeepout = 65;

    const rulerTicksHTML = majorTicksData.map((d, i) => {
        let label = ''; const tickPx = (d.pctLeft / 100) * trackWidthPx;
        if (i === centerTickIndex) {
            label = d.date.toLocaleString(dateLocale, {
                day: '2-digit', month: 'short', year: 'numeric',
                hour: (activeScale.type === 'hour' || activeScale.type === 'minute') ? '2-digit' : undefined,
                minute: (activeScale.type === 'hour' || activeScale.type === 'minute') ? '2-digit' : undefined
            });
        } else if (Math.abs(tickPx - centerTickPx) > centerKeepout) {
            if (activeScale.type === 'year') label = d.date.getFullYear();
            else if (activeScale.type === 'month') label = d.date.toLocaleString(dateLocale, { month: 'short', year: 'numeric' });
            else if (activeScale.type === 'day') label = d.date.toLocaleString(dateLocale, { day: 'numeric', month: 'short' });
            else if (activeScale.type === 'hour' || activeScale.type === 'minute') {
