    const laneCount = Math.max(1, orderedTags.length);
    const laneHeight = Math.max(24, (containerHeight - 55) / laneCount);

    // --- [ SubBlock: Chrono Bounds & Smart Labels ] ---
    const validData = data.filter(d => d.startDate && !isNaN(d.startDate.min));
    const minTimeRaw = validData.length > 0 ? validData.at(0).startDate.min : new Date().getTime();
    let maxTimeRaw = minTimeRaw;
    
    validData.forEach(d => {
        if (d.endDate && !isNaN(d.endDate.max) && d.endDate.max > maxTimeRaw) maxTimeRaw = d.endDate.max;
        else if (d.startDate.min > maxTimeRaw) maxTimeRaw = d.startDate.min;
    });

    const uniqueStarts = Array.from(new Set(validData.map(d => d.startDate.min))).sort((a, b) => a - b);
    const rawTimeRange = Math.max(maxTimeRaw - minTimeRaw, 86400000);
    const padMs = rawTimeRange * 0.05;
    const renderMinTime = minTimeRaw - padMs;
    const renderMaxTime = maxTimeRaw + padMs;
    const renderTimeRange = renderMaxTime - renderMinTime;

    const measureTextWidth = (text) => {
        const canvas = document.createElement('canvas'); const context = canvas.getContext('2d');
        context.font = '400 12px "Noto Sans", sans-serif'; return context.measureText(text).width;
    };

    const formatLabelSmart = (titleStr) => {
        const maxPx = 300; const words = titleStr.split(' ');
        let targetLines = words.length > 1 ? (measureTextWidth(titleStr) > 280 ? 3 : 2) : 1;
        if (targetLines === 1) return { lines: [titleStr], pxWidth: measureTextWidth(titleStr) + 35 };

        let bestSplit = []; let bestScore = Infinity;
        if (targetLines === 2) {
            for (let i = 1; i < words.length; i++) {
                let l1 = words.slice(0, i).join(' '), l2 = words.slice(i).join(' ');
                let w1 = measureTextWidth(l1), w2 = measureTextWidth(l2);
                let score = Math.max(w1, w2) + Math.abs(w1 - w2) * 0.8;
                if (score < bestScore) { bestScore = score; bestSplit = [l1, l2]; }
            }
        } else {
            for (let i = 1; i < words.length - 1; i++) {
                for (let j = i + 1; j < words.length; j++) {
                    let l1 = words.slice(0, i).join(' '), l2 = words.slice(i, j).join(' '), l3 = words.slice(j).join(' ');
                    let w1 = measureTextWidth(l1), w2 = measureTextWidth(l2), w3 = measureTextWidth(l3);
                    let maxW = Math.max(w1, w2, w3), minW = Math.min(w1, w2, w3);
                    let score = maxW + (maxW - minW) * 0.8;
                    if (score < bestScore) { bestScore = score; bestSplit = [l1, l2, l3]; }
                }
            }
        }

        let lines = bestSplit.length ? bestSplit : [titleStr];
        if (lines.length === 3) {
            let last = lines.at(2);
            if (measureTextWidth(last) > maxPx) {
                while (measureTextWidth(last + '...') > maxPx && last.length > 0) last = last.slice(0, -1);
                lines.splice(2, 1, last.trim() + '...');
            }
        } else if (lines.length === 2) {
            let last = lines.at(1);
            if (measureTextWidth(last) > maxPx * 1.3) {
                while (measureTextWidth(last + '...') > maxPx * 1.3 && last.length > 0) last = last.slice(0, -1);
                lines.splice(1, 1, last.trim() + '...');
            }
        }
        return { lines, pxWidth: Math.max(60, Math.max(...lines.map(l => measureTextWidth(l))) + 35) };
    };

    // --- [ SubBlock: Kinetic Camera ] ---
    useEffect(() => {
        const visibleMs = renderTimeRange / zoomLevel;
        const secs = visibleMs / 1000; const mins = secs / 60; const hrs = mins / 60; const days = hrs / 24; const mos = days / 30.44; const yrs = days / 365.25;
        let str = `${Math.round(mins)} Minutes`;
        if (yrs >= 1) str = `${Math.round(yrs)} Years`; else if (mos >= 1) str = `${Math.round(mos)} Months`; else if (days >= 1) str = `${Math.round(days)} Days`; else if (hrs >= 1) str = `${Math.round(hrs)} Hours`;
        setVisibleTimeSpan(`Span: ${str}`);
    }, [zoomLevel, renderTimeRange, setVisibleTimeSpan]);

    const getExactNodeScrollPos = (nodeGlobalIdx, trackW, containerW) => {
        const activeNode = data[nodeGlobalIdx];
        if (!activeNode || !activeNode.startDate) return 0;
        const basePx = ((activeNode.startDate.min - renderMinTime) / renderTimeRange) * trackW;
        return basePx - (containerW / 2);
    };

    useEffect(() => {
        const activeDataIndex = validData.findIndex(d => d.id === activeIndex);
