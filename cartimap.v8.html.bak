          };

          const formatLabelSmart = (titleStr) => {
            const maxPx = 300;
            const words = titleStr.split(' ');
            let targetLines = words.length > 1 ? (measureTextWidth(titleStr) > 280 ? 3 : 2) : 1;
            if (targetLines === 1) return { lines: [titleStr], pxWidth: measureTextWidth(titleStr) + 35 };
            let bestSplit = [];
            let bestScore = Infinity;
            if (targetLines === 2) {
              for (let i = 1; i < words.length; i++) {
                let l1 = words.slice(0, i).join(' '), l2 = words.slice(i).join(' ');
                let w1 = measureTextWidth(l1), w2 = measureTextWidth(l2);
                let score = Math.max(w1, w2) + Math.abs(w1 - w2) * 0.8;
                if (score < bestScore) { bestScore = score; bestSplit = [l1, l2]; }
              }
            } else {
              for (let i = 1; i < words.length - 1; i++) {
                for (let j = i + 1; j < words.length; j++) {
                  let l1 = words.slice(0, i).join(' '), l2 = words.slice(i, j).join(' '), l3 = words.slice(j).join(' ');
                  let w1 = measureTextWidth(l1), w2 = measureTextWidth(l2), w3 = measureTextWidth(l3);
                  let maxW = Math.max(w1, w2, w3), minW = Math.min(w1, w2, w3);
                  let score = maxW + (maxW - minW) * 0.8;
                  if (score < bestScore) { bestScore = score; bestSplit = [l1, l2, l3]; }
                }
              }
            }
            let lines = bestSplit.length ? bestSplit : [titleStr];
            if (lines.length === 3) {
              let last = lines.at(2);
              if (measureTextWidth(last) > maxPx) {
                while (measureTextWidth(last + '...') > maxPx && last.length > 0) last = last.slice(0, -1);
                lines.splice(2, 1, last.trim() + '...');
              }
            } else if (lines.length === 2) {
              let last = lines.at(1);
              if (measureTextWidth(last) > maxPx * 1.3) {
                while (measureTextWidth(last + '...') > maxPx * 1.3 && last.length > 0) last = last.slice(0, -1);
                lines.splice(1, 1, last.trim() + '...');
              }
            }
            return { lines, pxWidth: Math.max(60, Math.max(...lines.map(l => measureTextWidth(l))) + 35) };
          };

          useEffect(() => {
            const visibleMs = renderTimeRange / zoomLevel;
            const secs = visibleMs / 1000;
            const mins = secs / 60;
            const hrs = mins / 60;
            const days = hrs / 24;
            const mos = days / 30.44;
            const yrs = days / 365.25;
            let str = `${Math.round(mins)} Minutes`;
            if (yrs >= 1) str = `${Math.round(yrs)} Years`;
            else if (mos >= 1) str = `${Math.round(mos)} Months`;
            else if (days >= 1) str = `${Math.round(days)} Days`;
            else if (hrs >= 1) str = `${Math.round(hrs)} Hours`;
            setVisibleTimeSpan(`Span: ${str}`);
          }, [zoomLevel, renderTimeRange, setVisibleTimeSpan]);

          useEffect(() => {
            const activeDataIndex = validData.findIndex(d => d.id === activeIndex);
            if (activeDataIndex >= 0 && wrapperRef.current && !dragRef.current.isDragging) {
              const activeNode = validData.at(activeDataIndex);
              const sT = activeNode.startDate.min;
              const { pxWidth } = formatLabelSmart(safeStripHTML(activeNode.title));
              const containerW = wrapperRef.current.clientWidth || 1000;
              const targetTrackW = Math.max(containerW, containerW * zoomLevel);
              const scrollPos = ((sT - renderMinTime) / renderTimeRange * targetTrackW) + (pxWidth / 2) - (containerW / 2);
              wrapperRef.current.scrollTo({ left: scrollPos, behavior: 'smooth' });
            }
          }, [activeIndex]);

          useEffect(() => {
            if (validData.length > 1 && wrapperRef.current && !dragRef.current.isDragging && activeIndex !== prevActiveIndexRef.current) {
              prevActiveIndexRef.current = activeIndex;
              if (zoomLock === 'hard') return;
              if (zoomLock === 'soft') setZoomLock('auto');
              const timeoutId = setTimeout(() => {
                const activeDataIndex = validData.findIndex(d => d.id === activeIndex);
                if (activeDataIndex >= 0) {
                  let clusterMin = validData.at(Math.max(0, activeDataIndex - 2)).startDate.min;
                  let clusterMax = validData.at(Math.min(validData.length - 1, activeDataIndex + 2)).startDate.min;
                  for (let i = Math.max(0, activeDataIndex - 2); i <= Math.min(validData.length - 1, activeDataIndex + 2); i++) {
                    const node = validData.at(i);
                    if (node.endDate && !isNaN(node.endDate.max)) {
                      clusterMax = Math.max(clusterMax, node.endDate.max);
                    }
                    clusterMax = Math.max(clusterMax, node.startDate.min);
                    clusterMin = Math.min(clusterMin, node.startDate.min);
                  }
                  const idealZoom = (0.6 * renderTimeRange) / Math.max(clusterMax - clusterMin, 1800000);
                  const clampedZoom = Math.min(Math.max(1, idealZoom), 300);
                  const activeNode = validData.at(activeDataIndex);
                  const sT = activeNode.startDate.min;
                  const { pxWidth } = formatLabelSmart(safeStripHTML(activeNode.title));
                  const containerW = wrapperRef.current.clientWidth || 1000;
                  scrollTargetRef.current = (((sT - renderMinTime) / renderTimeRange * Math.max(containerW, containerW * clampedZoom)) + (pxWidth / 2)) - (containerW / 2);
                  setZoomLevel(clampedZoom);
                }
              }, 500);
              return () => clearTimeout(timeoutId);
            }
          }, [activeIndex, data, zoomLock, setZoomLock]);

          useLayoutEffect(() => {
            if (scrollTargetRef.current !== null && wrapperRef.current) {
              wrapperRef.current.scrollTo({ left: scrollTargetRef.current, behavior: 'auto' });
              scrollTargetRef.current = null;
            }
          }, [zoomLevel]);

          const handleManualZoom = (newZoom, centerType = 'center', eventX = 0) => {
            if (!wrapperRef.current) return;
            const containerW = wrapperRef.current.clientWidth;
            const scrollPos = wrapperRef.current.scrollLeft;
            const anchorPx = centerType === 'mouse' ? scrollPos + eventX : scrollPos + (containerW / 2);
            const centerPct = anchorPx / Math.max(containerW, containerW * zoomLevel);
            scrollTargetRef.current = (centerPct * Math.max(containerW, containerW * newZoom)) - (centerType === 'mouse' ? eventX : (containerW / 2));
            setZoomLevel(newZoom);
          };

          const onDown = (e) => {
            if (zoomLock !== 'hard') setZoomLock('soft');
            if (e.touches && e.touches.length === 2) {
              const t1 = Array.from(e.touches).at(0);
              const t2 = Array.from(e.touches).at(1);
              touchZoomRef.current = {
                initialDist: Math.hypot(t1.clientX - t2.clientX, t1.clientY - t2.clientY),
                initialZoom: zoomLevel
              };
              return;
            }
            const t1 = e.touches ? Array.from(e.touches).at(0) : e;
            const x = t1.clientX;
            dragRef.current = { isDragging: true, startX: x - wrapperRef.current.offsetLeft, scrollLeft: wrapperRef.current.scrollLeft };
            wrapperRef.current.classList.add('is-dragging');
          };

          const onUp = () => {
            dragRef.current.isDragging = false;
            wrapperRef.current?.classList.remove('is-dragging');
          };

          const onMove = (e) => {
            if (e.touches && e.touches.length === 2) {
              e.preventDefault();
              const t1 = Array.from(e.touches).at(0);
              const t2 = Array.from(e.touches).at(1);
              const scale = Math.hypot(t1.clientX - t2.clientX, t1.clientY - t2.clientY) / touchZoomRef.current.initialDist;
              handleManualZoom(Math.min(Math.max(touchZoomRef.current.initialZoom * scale, 1), 500), 'center');
              return;
            }
            if (!dragRef.current.isDragging) return;
            if (!e.touches) e.preventDefault();
            const t1 = e.touches ? Array.from(e.touches).at(0) : e;
            wrapperRef.current.scrollLeft = dragRef.current.scrollLeft - ((t1.clientX - wrapperRef.current.offsetLeft - dragRef.current.startX) * 2);
          };

          const onWheel = (e) => {
            e.preventDefault();
            if (zoomLock !== 'hard') setZoomLock('soft');
            handleManualZoom(e.deltaY < 0 ? Math.min(zoomLevel * 1.5, 500) : Math.max(zoomLevel / 1.5, 1), 'mouse', e.clientX - wrapperRef.current.getBoundingClientRect().left);
          };

          const onScroll = () => {
            if (scrollTimeout.current) clearTimeout(scrollTimeout.current);
            scrollTimeout.current = setTimeout(() => {
              if (wrapperRef.current) setViewLeftEdge(wrapperRef.current.scrollLeft);
            }, 100);
          };

          if (validData.length === 0) return html`<div style="padding:1rem;">No valid temporal data.</div>`;

          const containerW = wrapperRef.current ? wrapperRef.current.clientWidth : 1000;
          const trackWidthPx = Math.max(containerW, containerW * zoomLevel);
          const visibleTimeSpanMs = renderTimeRange / zoomLevel;
          const spansMultipleDays = visibleTimeSpanMs > 86400000;
          const targetMsPerMajorTick = Math.max((120 / containerW) * visibleTimeSpanMs, visibleTimeSpanMs / 12);
          const SECOND = 1000;
          const MINUTE = 60 * SECOND;
          const HOUR = 60 * MINUTE;
          const DAY = 24 * HOUR;
          const MONTH = 30 * DAY;
          const YEAR = 365.25 * DAY;

          const scaleConfigs = [
            { ms: 1000 * YEAR, type: 'year', step: 1000, minorType: 'year', minorStep: 100, minorCount: 10 },
            { ms: 100 * YEAR, type: 'year', step: 100, minorType: 'year', minorStep: 10, minorCount: 10 },
            { ms: 10 * YEAR, type: 'year', step: 10, minorType: 'year', minorStep: 1, minorCount: 10 },
            { ms: 2 * YEAR, type: 'year', step: 2, minorType: 'month', minorStep: 2, minorCount: 12 },
            { ms: YEAR, type: 'year', step: 1, minorType: 'month', minorStep: 1, minorCount: 12 },
            { ms: 6 * MONTH, type: 'month', step: 6, minorType: 'month', minorStep: 1, minorCount: 6 },
            { ms: 3 * MONTH, type: 'month', step: 3, minorType: 'day', minorStep: 10, minorCount: 9 },
            { ms: MONTH, type: 'month', step: 1, minorType: 'day', minorStep: 5, minorCount: 6 },
            { ms: 14 * DAY, type: 'day', step: 14, minorType: 'day', minorStep: 2, minorCount: 7 },
            { ms: 7 * DAY, type: 'day', step: 7, minorType: 'day', minorStep: 1, minorCount: 7 },
            { ms: 2 * DAY, type: 'day', step: 2, minorType: 'hour', minorStep: 4, minorCount: 12 },
            { ms: DAY, type: 'day', step: 1, minorType: 'hour', minorStep: 3, minorCount: 8 },
            { ms: 12 * HOUR, type: 'hour', step: 12, minorType: 'hour', minorStep: 1, minorCount: 12 },
            { ms: 6 * HOUR, type: 'hour', step: 6, minorType: 'hour', minorStep: 1, minorCount: 6 },
            { ms: 2 * HOUR, type: 'hour', step: 2, minorType: 'minute', minorStep: 15, minorCount: 8 },
            { ms: HOUR, type: 'hour', step: 1, minorType: 'minute', minorStep: 10, minorCount: 6 },
            { ms: 30 * MINUTE, type: 'minute', step: 30, minorType: 'minute', minorStep: 5, minorCount: 6 },
            { ms: 15 * MINUTE, type: 'minute', step: 15, minorType: 'minute', minorStep: 1, minorCount: 15 },
            { ms: 10 * MINUTE, type: 'minute', step: 10, minorType: 'minute', minorStep: 1, minorCount: 10 },
            { ms: 5 * MINUTE, type: 'minute', step: 5, minorType: 'minute', minorStep: 1, minorCount: 5 },
            { ms: MINUTE, type: 'minute', step: 1, minorType: 'second', minorStep: 10, minorCount: 6 }
          ];

          let activeScale = scaleConfigs.find(c => targetMsPerMajorTick > c.ms) || scaleConfigs.at(-1);
          
          const visibleLeftMs = renderMinTime + (viewLeftEdge / trackWidthPx) * renderTimeRange;
          const visibleRightMs = renderMinTime + ((viewLeftEdge + containerW) / trackWidthPx) * renderTimeRange;
          const viewportCenterMs = visibleLeftMs + ((visibleRightMs - visibleLeftMs) / 2);

          // [FIX] Phase 1 4D Telemetry Hoisting: Broadcast active bounds back to AppOrchestrator
          useEffect(() => {
            if (setVisibleTimeBounds && !isNaN(visibleLeftMs) && !isNaN(visibleRightMs)) {
              setVisibleTimeBounds([visibleLeftMs, visibleRightMs]);
            }
          }, [visibleLeftMs, visibleRightMs, setVisibleTimeBounds]);

          let iterDate = new Date(Math.max(renderMinTime, visibleLeftMs - (activeScale.ms * 2)));
          iterDate.setMilliseconds(0);

          if (activeScale.type === 'year') {
            iterDate.setMonth(0, 1);
            iterDate.setHours(0, 0, 0, 0);
            iterDate.setFullYear(Math.floor(iterDate.getFullYear() / activeScale.step) * activeScale.step);
          } else if (activeScale.type === 'month') {
            iterDate.setDate(1);
            iterDate.setHours(0, 0, 0, 0);
            iterDate.setMonth(Math.floor(iterDate.getMonth() / activeScale.step) * activeScale.step);
          } else if (activeScale.type === 'day') {
            iterDate.setHours(0, 0, 0, 0);
            iterDate.setDate(Math.floor((iterDate.getDate() - 1) / activeScale.step) * activeScale.step + 1);
          } else if (activeScale.type === 'hour') {
            iterDate.setMinutes(0, 0, 0);
            iterDate.setHours(Math.floor(iterDate.getHours() / activeScale.step) * activeScale.step);
          } else if (activeScale.type === 'minute') {
            iterDate.setSeconds(0, 0);
            iterDate.setMinutes(Math.floor(iterDate.getMinutes() / activeScale.step) * activeScale.step);
          }

          let safety = 0;
          const stopTime = Math.min(renderMaxTime, visibleRightMs + (activeScale.ms * 2));
          const majorTicksData = [];
          const minorTicksData = [];

          while (iterDate.getTime() <= stopTime && safety < 1000) {
            safety++;
            const t = iterDate.getTime();
            if (t >= renderMinTime) {
              const pctLeft = ((t - renderMinTime) / renderTimeRange) * 100;
              majorTicksData.push({ t, pctLeft, date: new Date(iterDate) });
            }

            let nextMajor = new Date(iterDate);
            if (activeScale.type === 'year') nextMajor.setFullYear(nextMajor.getFullYear() + activeScale.step);
            else if (activeScale.type === 'month') nextMajor.setMonth(nextMajor.getMonth() + activeScale.step);
            else if (activeScale.type === 'day') nextMajor.setDate(nextMajor.getDate() + activeScale.step);
            else if (activeScale.type === 'hour') nextMajor.setHours(nextMajor.getHours() + activeScale.step);
            else if (activeScale.type === 'minute') nextMajor.setMinutes(nextMajor.getMinutes() + activeScale.step);

            let minorIter = new Date(iterDate);
            let minorSafety = 0;
            let minorIndex = 0;

            while (minorSafety < 100) {
              minorSafety++;
              minorIndex++;
              if (activeScale.minorType === 'year') minorIter.setFullYear(minorIter.getFullYear() + activeScale.minorStep);
              else if (activeScale.minorType === 'month') minorIter.setMonth(minorIter.getMonth() + activeScale.minorStep);
              else if (activeScale.minorType === 'day') minorIter.setDate(minorIter.getDate() + activeScale.minorStep);
              else if (activeScale.minorType === 'hour') minorIter.setHours(minorIter.getHours() + activeScale.minorStep);
              else if (activeScale.minorType === 'minute') minorIter.setMinutes(minorIter.getMinutes() + activeScale.minorStep);
              else if (activeScale.minorType === 'second') minorIter.setSeconds(minorIter.getSeconds() + activeScale.minorStep);

              if (minorIter.getTime() >= nextMajor.getTime()) break;

              const minorT = minorIter.getTime();
              if (minorT >= renderMinTime && minorT <= renderMaxTime) {
                const minorTickPx = (((minorT - renderMinTime) / renderTimeRange)) * trackWidthPx;
                const majorPx = ((t - renderMinTime) / renderTimeRange) * trackWidthPx;
                const nextMajorPx = ((nextMajor.getTime() - renderMinTime) / renderTimeRange) * trackWidthPx;
                minorTicksData.push({ t: minorT, px: minorTickPx, majorPx, nextMajorPx, date: new Date(minorIter), minorIndex });
              }
            }
            iterDate = nextMajor;
          }

          let centerTickIndex = -1;
          let minDist = Infinity;
          majorTicksData.forEach((d, i) => {
            if (d.t >= visibleLeftMs && d.t <= visibleRightMs) {
              const dist = Math.abs(d.t - viewportCenterMs);
              if (dist < minDist) { minDist = dist; centerTickIndex = i; }
            }
          });

          const centerTickPx = centerTickIndex !== -1 ? (majorTicksData.at(centerTickIndex).pctLeft / 100) * trackWidthPx : -1000;
          const centerKeepout = 65;

          const rulerTicksHTML = majorTicksData.map((d, i) => {
            let label = '';
            const tickPx = (d.pctLeft / 100) * trackWidthPx;
            
            if (i === centerTickIndex) {
              label = d.date.toLocaleString(dateLocale, {
                day: '2-digit', month: 'short', year: 'numeric',
                hour: (activeScale.type === 'hour' || activeScale.type === 'minute') ? '2-digit' : undefined,
                minute: (activeScale.type === 'hour' || activeScale.type === 'minute') ? '2-digit' : undefined
              });
            } else if (Math.abs(tickPx - centerTickPx) > centerKeepout) {
              if (activeScale.type === 'year') label = d.date.getFullYear();
              else if (activeScale.type === 'month') label = d.date.toLocaleString(dateLocale, { month: 'short', year: 'numeric' });
              else if (activeScale.type === 'day') label = d.date.toLocaleString(dateLocale, { day: 'numeric', month: 'short' });
              else if (activeScale.type === 'hour' || activeScale.type === 'minute') {
                if (spansMultipleDays && d.date.getHours() === 0 && d.date.getMinutes() === 0) {
                  label = d.date.toLocaleString(dateLocale, { day: 'numeric', month: 'short' });
                } else {
                  label = d.date.getMinutes() === 0 ? d.date.getHours().toString() : ':' + d.date.getMinutes().toString().padStart(2, '0');
                }
              }
            }
            return html`
              <div class="timeline-ruler-tick" style="left: ${d.pctLeft}%;">
                <div style="width: 2px; height: 10px; background: #666; margin-bottom: 2px;"></div>
                <div style="font-size: 0.75rem; white-space: nowrap; font-weight: normal; color: #444;">${label}</div>
              </div>
            `;
          });

          const minorTicksHTML = minorTicksData.map(m => {
            const distCurrent = Math.abs(m.px - m.majorPx);
            const distNext = Math.abs(m.px - m.nextMajorPx);
            const distCenter = Math.abs(m.px - centerTickPx);
            let hideMinor = distCurrent < 35 || distNext < 35;
            let showLabelText = false;
            
            if (!hideMinor && distCurrent > 20) {
              if (activeScale.minorCount % 2 === 0) {
                showLabelText = (m.minorIndex % 2 === 0);
              } else {
                showLabelText = (m.minorIndex === Math.floor(activeScale.minorCount / 2));
              }
            }

            let minorLabel = '';
            if (showLabelText && distCenter > centerKeepout) {
              if (activeScale.minorType === 'year') minorLabel = m.date.getFullYear();
              else if (activeScale.minorType === 'month') minorLabel = m.date.toLocaleString(dateLocale, { month: 'short' });
              else if (activeScale.minorType === 'day') minorLabel = m.date.getDate();
              else if (activeScale.minorType === 'hour' || activeScale.minorType === 'minute') {
                minorLabel = m.date.getMinutes() === 0 ? m.date.getHours().toString() : ':' + m.date.getMinutes().toString().padStart(2, '0');
              }
            }

            if (m.px >= viewLeftEdge - 50 && m.px <= viewLeftEdge + containerW + 50) {
              return html`
                <div style="position: absolute; left: ${((m.t - renderMinTime) / renderTimeRange) * 100}%; top: 0; width: 1px; height: ${minorLabel ? '7px' : '5px'}; background: #aaa; z-index: 4;">
                  ${minorLabel ? html`<div style="position: absolute; left: -20px; right: -20px; top: 7px; text-align: center; font-size: 0.6rem; color: #888; letter-spacing: -0.5px;">${minorLabel}</div>` : ''}
                </div>
              `;
            }
            return null;
          });

          const stackRegistry = {};
          const markers = validData.map((item, index) => {
            const globalIndex = data.findIndex(d => d.id === item.id);
            const startPct = Number((((item.startDate.min - renderMinTime) / renderTimeRange) * 100).toFixed(4));
            const tagIndices = getParsedTags(item.tags).map(t => orderedTags.indexOf(t)).filter(idx => idx !== -1);
            const laneIdx = tagIndices.length > 0 ? Math.min(...tagIndices) : 0;
            
            const stackKey = `${item.startDate.min}_${laneIdx}`;
            if (!stackRegistry[stackKey]) stackRegistry[stackKey] = 0;
            const stackDepth = stackRegistry[stackKey];
            stackRegistry[stackKey]++;
            const xOffset = stackDepth * 6;
            const yOffset = stackDepth * 4;

            let endPct = startPct;
            if (item.endDate && !isNaN(item.endDate.max) && item.endDate.max > item.startDate.min) {
              endPct = Number((((item.endDate.max - renderMinTime) / renderTimeRange) * 100).toFixed(4));
            }
            const hasDuration = (endPct - startPct) > 0.001;
            const isActive = globalIndex === activeIndex;
            const topPos = (laneIdx * laneHeight) + 5;
            const blockHeight = ((tagIndices.length > 0 ? Math.max(...tagIndices) : 0) - laneIdx + 1) * laneHeight;
            
            const { lines, pxWidth } = formatLabelSmart(safeStripHTML(item.title));
            const hasMedia = item.media && item.media.length > 0;

            let xAxisMarker = '';
            let isDashed = false;
            let isApprox = false;

            if (item.startDate.isEDTF) {
              const obj = item.startDate.obj;
              if (obj.approximate) isApprox = true;
              if (obj.uncertain) isDashed = true;
              if (obj.type === 'Set') {
                const setEndPct = Number((((obj.max - renderMinTime) / renderTimeRange) * 100).toFixed(4));
                xAxisMarker = html`<div style="position: absolute; bottom: 0; left: 0; width: calc(${setEndPct - startPct}% + 6px); height: 8px; background: rgba(255, 215, 0, 0.2); border: 1px dashed gold; border-radius: 4px; z-index: 900; transform: translateX(-3px);"></div>`;
              } else if (obj.type === 'List') {
                const setEndPct = Number((((obj.max - renderMinTime) / renderTimeRange) * 100).toFixed(4));
                const subDots = obj.values.map(v => {
                  const vPct = Number((((v.min - item.startDate.min) / renderTimeRange) * trackWidthPx).toFixed(2));
                  return html`<div style="position: absolute; bottom: 1px; left: ${vPct}px; width: 4px; height: 4px; border-radius: 50%; background: #cc0000; transform: translateX(-2px);"></div>`;
                });
                xAxisMarker = html`<div style="position: absolute; bottom: 0; left: 0; width: ${setEndPct - startPct}%; height: 1px; background: rgba(204,0,0,0.4); z-index: 900;">${subDots}</div>`;
              }
            }

            if (!xAxisMarker) {
              if (hasDuration) {
                const gradStyle = (item.endDate && item.endDate.isEDTF && item.endDate.isOpen)
                  ? `background: linear-gradient(90deg, ${isActive ? 'rgba(0,122,204,0.6)' : 'rgba(204,0,0,0.4)'} 0%, transparent 100%);`
                  : `background: ${isActive ? 'rgba(0,122,204,0.4)' : 'rgba(204,0,0,0.3)'}; border: 1px solid ${isActive ? '#007acc' : '#cc0000'};`;
                xAxisMarker = html`<div style="position: absolute; bottom: 0; left: 0; width: 100%; min-width: 2px; height: 6px; ${gradStyle} clip-path: polygon(0 0, 100% calc(100% - 5px), 100% 100%, 0 100%); z-index: 900;"></div>`;
              } else {
                let styleStr = `position: absolute; bottom: 0; left: -3px; width: 6px; height: 6px; border-radius: 50%; z-index: 900; box-sizing: content-box; `;
                if (isApprox) styleStr += `background: radial-gradient(circle, gold 40%, transparent 100%); border: none; `;
                else styleStr += `background: ${isActive ? '#007acc' : '#cc0000'}; `;
                if (isDashed) styleStr += `border: 2px dashed #ff4500; background: transparent; `;
                else if (!isApprox) styleStr += `border: 1px solid #fff; `;
                xAxisMarker = html`<div style="${styleStr}"></div>`;
              }
            }

            return html`
              <div id="timeline-marker-${globalIndex}" class="event-group ${isActive ? 'active' : ''}" style="left: calc(${startPct}% + ${xOffset}px); top: calc(${topPos}px + ${yOffset}px); bottom: 28px; ${hasDuration ? `width: calc(${endPct - startPct}% - ${xOffset}px); min-width: 4px;` : `width: ${pxWidth}px;`}" onClick=${() => setActiveIndex(globalIndex)}>
                ${isActive ? html`<div style="position: absolute; left: 0; top: ${blockHeight / 2}px; bottom: 0; width: 2px; background: #007acc; z-index: 999;"></div>` : ''}
                ${xAxisMarker}
                <div class="event-block" style="position: absolute; top: ${blockHeight / 2}px; transform: translateY(-50%); left: 0; min-height: ${blockHeight}px; height: auto; --lane-h: ${laneHeight}px; background: ${isActive ? '#007acc' : '#f4f4f5'}; color: ${isActive ? '#fff' : '#444'}; z-index: 5; width: ${pxWidth}px;">
                  ${hasMedia ? html`<svg style="position: absolute; left: 2px; top: 50%; transform: translateY(-50%); width: 10px; height: 10px; opacity: 0.8;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>` : ''}
                  <div style="display: flex; flex-direction: column; width: 100%; letter-spacing: -0.2px;">
                    ${lines.map(l => html`<div style="white-space: nowrap; overflow: hidden; width: 100%;">${l}</div>`)}
                  </div>
                </div>
              </div>
            `;
          });

          return html`
            <div style="position: relative; width: 100%; height: 100%; display: flex; flex-direction: column; overflow: hidden;">
              <div class="timeline-control-cluster" style="top: 15px; flex-direction: row;">
                <button class="status-btn" style="border: none; border-right: 1px solid #eee; border-radius: 0;" onClick=${() => setIsTimelineMinimized(true)} title="Minimize Timeline">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                </button>
                <button class="status-btn" style="border: none; border-radius: 0;" onClick=${() => {
                  if (!isTimelineExpanded) {
                    const appNode = document.getElementById('app-layout');
                    if (appNode) appNode.style.setProperty('--timeline-height', `${timelineRequiredHeight}px`);
                    setIsTimelineExpanded(true);
                  } else {
                    const appNode = document.getElementById('app-layout');
                    if (appNode) appNode.style.setProperty('--timeline-height', '10%');
                    setIsTimelineExpanded(false);
                  }
                }} title=${isTimelineExpanded ? "Restore Height" : "Maximize Swimlanes"}>
                  ${isTimelineExpanded
                    ? html`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="9" width="12" height="12" rx="1"></rect><path d="M9 3h9a1 1 0 0 1 1 1v9"></path></svg>`
                    : html`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>`
                  }
                </button>
              </div>
              <div class="timeline-control-cluster temporal" style="top: 52px;">
                <button class="status-btn" style="border: none; border-bottom: 1px solid #eee; border-radius: 0;" onClick=${() => { if(zoomLock !== 'hard') setZoomLock('soft'); handleManualZoom(Math.min(zoomLevel * 1.5, 500), 'center'); }} title="Zoom In">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                </button>
                <div class="zoom-factor" style="height: 28px; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; color: #222; background: #fff; border-bottom: 1px solid #eee; font-family: monospace; margin: 0; padding: 0;" title="Current Zoom Factor">${Math.round(zoomLevel)}x</div>
                <button class="status-btn" style="border: none; border-bottom: 1px solid #eee; border-radius: 0;" onClick=${() => { if(zoomLock !== 'hard') setZoomLock('soft'); handleManualZoom(Math.max(zoomLevel / 1.5, 1), 'center'); }} title="Zoom Out">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                </button>
                <button class="status-btn" style="border: none; border-radius: 0;" onClick=${() => setZoomLock(p => p === 'hard' ? 'auto' : 'hard')} title="Toggle Auto-Zoom Lock">
                  ${zoomLock === 'hard'
                    ? html`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d32f2f" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`
                    : html`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 9.9-1"></path></svg>`
                  }
                </button>
              </div>
              <div class="timeline-scroll-wrapper" ref=${wrapperRef} onScroll=${onScroll} onMouseDown=${onDown} onMouseLeave=${onUp} onMouseUp=${onUp} onMouseMove=${onMove} onTouchStart=${onDown} onTouchEnd=${onUp} onTouchMove=${onMove} onWheel=${onWheel}>
                <div class="timeline-track-container" style="position: relative; width: ${trackWidthPx}px; flex-shrink: 0; height: 100%; box-sizing: border-box;">
                  <div style="position: absolute; top: 5px; left: 0; right: 0; bottom: 33px; pointer-events: none; z-index: 0;">
                    ${orderedTags.map((tag, i) => html`
                      <div class="tag-lane" style="top: ${i * laneHeight}px; height: ${laneHeight}px; background: ${i % 2 === 0 ? 'rgba(0,0,0,0.03)' : 'transparent'};">
                        <div class="tag-lane-label" style="background: ${i % 2 === 0 ? '#f4f4f4' : '#fcfcfc'}; pointer-events: auto;">${tag}</div>
                      </div>
                    `)}
                  </div>
                  <div class="timeline-axis" style="position: absolute; bottom: 0; left: 0; right: 0; height: 28px; background: #e0e0e0; border-top: 2px solid #999; z-index: 5;">
                    ${rulerTicksHTML}
                    ${minorTicksHTML}
                  </div>
                  ${markers}
                </div>
              </div>
            </div>
          `;
        };
        MODULE_VERSIONS['TimelineScrubber'] = 'v25.0.5';
        // === [ END MAJOR BLOCK ] ===
		
        // === [ MAJOR BLOCK: AppOrchestrator v3.1.0 ] ===
        const App = () => {
          const [logs, setLogs] = useState([]);
          const [rawCsvRows, setRawCsvRows] = useState([]);
          const [data, setData] = useState([]);
          const [aboutData, setAboutData] = useState(null);
          const [status, setStatus] = useState({ text: 'Initializing Engine...', progress: 10, isFading: false, active: false });
          const [activeIndex, setActiveIndex] = useState(0);
          const [slideHistory, setSlideHistory] = useState([]);
          const [isMonitorOpen, setIsMonitorOpen] = useState(false);
          const [isAboutOpen, setIsAboutOpen] = useState(false);
          const [isSettingsOpen, setIsSettingsOpen] = useState(false);
          const [isMenuOpen, setIsMenuOpen] = useState(false);
          const [isSearchOpen, setIsSearchOpen] = useState(false);
          const [searchQuery, setSearchQuery] = useState('');
          const [searchHistory, setSearchHistory] = useState(() => {
            try { return JSON.parse(localStorage.getItem('tm_search_history')) || []; }
            catch (e) { return []; }
          });
          const [maxPane, setMaxPane] = useState(null);
          const [isTimelineExpanded, setIsTimelineExpanded] = useState(false);
          const [isTimelineMinimized, setIsTimelineMinimized] = useState(false);
          const [timelineRequiredHeight, setTimelineRequiredHeight] = useState(200);
          
          const [polygonOpacity, setPolygonOpacity] = useState(() => {
            try { return parseFloat(localStorage.getItem('tm_polygon_opacity')) || 0.4; }
            catch (e) { return 0.4; }
          });
          const [showButtonText, setShowButtonText] = useState(() => {
            try { return JSON.parse(localStorage.getItem('tm_show_button_text')) ?? false; }
            catch (e) { return false; }
          });
          const [dateLocale, setDateLocale] = useState(() => {
            try { return localStorage.getItem('tm_date_locale') || 'en-GB'; }
            catch (e) { return 'en-GB'; }
          });
          const [dateEngineMode, setDateEngineMode] = useState(() => {
            try { return localStorage.getItem('tm_date_engine_mode') || 'auto'; }
            catch (e) { return 'auto'; }
          });
          const [maxAutoZoom, setMaxAutoZoom] = useState(() => {
            try { return parseInt(localStorage.getItem('tm_max_auto_zoom')) || 15; }
            catch (e) { return 15; }
          });
          const [minimapOffset, setMinimapOffset] = useState(() => {
            try { return parseInt(localStorage.getItem('tm_minimap_offset')) || -4; }
            catch (e) { return -4; }
          });

          const DEFAULT_BASEMAPS = [
            { id: 'carto-light', label: 'CartoDB Light', type: 'base', url: 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', format: 'xyz', maxZoom: 19, active: true, attrText: '© CartoDB', attrLink: 'https://carto.com/attributions', defaultOpacity: 1.0 },
            { id: 'esri-sat', label: 'Esri Wordls Satellite', type: 'base', url: 'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', format: 'xyz', maxZoom: 19, active: false, attrText: 'Tiles © Esri', attrLink: 'https://www.esri.com/', defaultOpacity: 1.0 },
            { id: 'esri-street', label: 'Esri World Street', type: 'base', url: 'https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}', format: 'xyz', maxZoom: 19, active: false, attrText: 'Tiles © Esri', attrLink: 'https://www.esri.com/', defaultOpacity: 1.0 },
            { id: 'esri-topo', label: 'Esri World Topo', type: 'base', url: 'https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}', format: 'xyz', maxZoom: 19, active: false, attrText: 'Tiles © Esri', attrLink: 'https://www.esri.com/', defaultOpacity: 1.0 },
            { id: 'osm', label: 'OpenStreetMap', type: 'base', url: 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', format: 'xyz', maxZoom: 19, active: false, attrText: '© OSM', attrLink: 'https://openstreetmap.org/copyright', defaultOpacity: 1.0 },
            { id: 'opentopo', label: 'OpenTopoMap (OSM)', type: 'base', url: 'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', format: 'xyz', maxZoom: 17, active: false, attrText: '© OpenTopoMap', attrLink: 'https://opentopomap.org', defaultOpacity: 1.0 },
            { id: 'protomaps-vector', label: 'Protomaps Vector Light (OSM)', type: 'base', url: 'https://api.protomaps.com/tiles/v3/{z}/{x}/{y}.mvt?key=YOUR_API_KEY_HERE', format: 'pbf', maxZoom: 15, active: false, attrText: '© Protomaps', attrLink: 'https://protomaps.com', defaultOpacity: 1.0 }
          ];

          const [basemapsRegistry, setBasemapsRegistry] = useState(DEFAULT_BASEMAPS);
          const [zoomLock, setZoomLock] = useState('auto');
          const [visibleTimeSpan, setVisibleTimeSpan] = useState('');
          
          // [FIX] Phase 1: Telemetry Hoisting - Shared timeline boundaries
          const [visibleTimeBounds, setVisibleTimeBounds] = useState([0, Infinity]);
          const hasInitializedRef = useRef(false);
          const appRef = useRef(null);

          const addLog = (msg, type = 'info') => setLogs(p => [...p, { time: new Date().toLocaleTimeString('en-US', { hour12: false }), msg, type }]);

          const getOmniParam = (key) => {
            const sp = new URLSearchParams(window.location.search);
            let val = sp.get(key) || sp.get(`amp;${key}`);
            if (val) return val;
            const hp = new URLSearchParams(window.location.hash.replace(/^#\/?\??/, ''));
            return hp.get(key) || hp.get(`amp;${key}`);
          };

          const jumpToSlide = (newIdx, isSequential = false) => {
            if (newIdx !== activeIndex && newIdx >= 0 && newIdx < data.length) {
              if (!isSequential) setSlideHistory(prev => [...prev, activeIndex]);
              setActiveIndex(newIdx);
            }
          };

          const goBack = () => {
            if (slideHistory.length > 0) {
              const prev = slideHistory.at(-1);
              setSlideHistory(h => h.slice(0, -1));
              setActiveIndex(prev);
            }
          };

          const resetLayoutPanes = () => {
            if (appRef.current) {
              const isDesktop = window.innerWidth >= 1024;
              // [FIX] Flex-Greed Default Splitting
              appRef.current.style.setProperty('--primary-split', isDesktop ? '50%' : '55%');
              appRef.current.style.setProperty('--secondary-split', '50%');
              appRef.current.style.setProperty('--timeline-height', '10%');
              setMaxPane(null);
              setIsTimelineExpanded(false);
              setIsTimelineMinimized(false);
              window.dispatchEvent(new Event('resize'));
            }
          };

          const formatSmartDate = (start, end, loc) => {
            if (!start) return 'Unknown Date';
            if (start.isEDTF || (end && end.isEDTF)) {
              const sTxt = start.text;
              const eTxt = end ? end.text : null;
              return eTxt && sTxt !== eTxt ? `${sTxt} — ${eTxt}` : sTxt;
            }
            const optsD = { day: 'numeric', month: 'short', year: 'numeric' };
            const optsT = { hour: '2-digit', minute: '2-digit' };
            const sDate = start.date ? start.date.toLocaleDateString(loc, optsD) : '';
            const sTime = start.date ? start.date.toLocaleTimeString(loc, optsT).replace(/^00:00$/, '') : '';
            if (!end || isNaN(end.min) || start.min === end.max) return sTime ? `${sDate}, ${sTime}` : sDate;
            const eDate = end.date ? end.date.toLocaleDateString(loc, optsD) : '';
            const eTime = end.date ? end.date.toLocaleTimeString(loc, optsT).replace(/^00:00$/, '') : '';
            const sParts = sDate.split(' ');
            const eParts = eDate.split(' ');
            const sDay = sParts.at(0); const sMon = sParts.at(1); const sYear = sParts.at(2);
            const eDay = eParts.at(0); const eMon = eParts.at(1); const eYear = eParts.at(2);
            if (sDate === eDate) return sTime && eTime && sTime !== eTime ? `${sDate}, ${sTime} — ${eTime}` : (sTime ? `${sDate}, ${sTime}` : sDate);
            if (sYear === eYear && sParts.length > 2) return sMon === eMon ? `${sDay} - ${eDate}${eTime ? `, ${eTime}` : ''}` : `${sDay} ${sMon} - ${eDate}${eTime ? `, ${eTime}` : ''}`;
            return `${sTime ? `${sDate}, ${sTime}` : sDate} — ${eTime ? `${eDate}, ${eTime}` : eDate}`;
          };

          const formatPlaces = (str) => {
            return str ? str.split(/[|\-·;]/).map(s => s.split(',').at(0).trim()).filter(Boolean).join(' | ') : '';
          };

          const executeSearch = (query) => {
            if (!query.trim()) return [];
            const q = query.toLowerCase();
            return data.filter(d => {
              return (d.title && d.title.toLowerCase().includes(q)) ||
              (d.description && d.description.toLowerCase().includes(q)) ||
              (d.place && d.place.toLowerCase().includes(q)) ||
              (d.tags && d.tags.some(t => t.toLowerCase().includes(q))) ||
              formatSmartDate(d.startDate, d.endDate, dateLocale).toLowerCase().includes(q);
            });
          };

          useEffect(() => {
            const handleKeyDown = (e) => {
              if (['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) return;
              if (e.key === 'ArrowRight') jumpToSlide(activeIndex + 1);
              else if (e.key === 'ArrowLeft') jumpToSlide(activeIndex - 1);
            };
            window.addEventListener('keydown', handleKeyDown);
            return () => window.removeEventListener('keydown', handleKeyDown);
          }, [activeIndex, data.length]);

          useEffect(() => {
            const updateAppHeight = () => document.documentElement.style.setProperty('--app-height', `${window.innerHeight}px`);
            updateAppHeight();
            let wasDesktop = window.innerWidth >= 1024;
            const handleResize = () => {
              updateAppHeight();
              const isDesktop = window.innerWidth >= 1024;
              if (isDesktop !== wasDesktop) { window.dispatchEvent(new Event('resize')); }
              wasDesktop = isDesktop;
            };
            window.addEventListener('resize', handleResize);
            return () => window.removeEventListener('resize', handleResize);
          }, []);

          const startPrimaryResize = (e) => {
            if (maxPane) return;
            const tStart = e.touches ? Array.from(e.touches).at(0) : e;
            const startX = tStart.clientX;
            const startY = tStart.clientY;
            const isDesktop = window.innerWidth >= 1024;
            const containerNode = appRef.current.querySelector('.core-viewports');
            const startVal = isDesktop ? appRef.current.querySelector('.content-slider-pane').offsetWidth : appRef.current.querySelector('.content-slider-pane').offsetHeight;
            const containerSize = isDesktop ? containerNode.offsetWidth : containerNode.offsetHeight;
            const onMove = (e2) => {
              const tCurrent = e2.touches ? Array.from(e2.touches).at(0) : e2;
              const currentX = tCurrent.clientX;
              const currentY = tCurrent.clientY;
              const delta = isDesktop ? (currentX - startX) : (startY - currentY);
              let pct = ((startVal + delta) / containerSize) * 100;
              if (pct < 15) pct = 15;
              if (pct > 85) pct = 85;
              appRef.current.style.setProperty('--primary-split', `${pct}%`);
            };
            const onUp = () => {
              document.removeEventListener('mousemove', onMove);
              document.removeEventListener('mouseup', onUp);
              document.removeEventListener('touchmove', onMove);
              document.removeEventListener('touchend', onUp);
              window.dispatchEvent(new Event('resize'));
            };
            document.addEventListener('mousemove', onMove);
            document.addEventListener('mouseup', onUp);
            document.addEventListener('touchmove', onMove, { passive: false });
            document.addEventListener('touchend', onUp);
          };

          const startSecondaryResize = (e) => {
            if (maxPane) return;
            const tStart = e.touches ? Array.from(e.touches).at(0) : e;
            const startX = tStart.clientX;
            const startY = tStart.clientY;
            const isDesktop = window.innerWidth >= 1024;
            const containerNode = appRef.current.querySelector('.visual-pane');
            const startVal = isDesktop ? appRef.current.querySelector('.map-pane').offsetHeight : appRef.current.querySelector('.map-pane').offsetWidth;
            const containerSize = isDesktop ? containerNode.offsetHeight : containerNode.offsetWidth;
            const onMove = (e2) => {
              const tCurrent = e2.touches ? Array.from(e2.touches).at(0) : e2;
              const currentX = tCurrent.clientX;
              const currentY = tCurrent.clientY;
              const delta = isDesktop ? (currentY - startY) : (currentX - startX);
              let pct = ((startVal + delta) / containerSize) * 100;
              if (pct < 10) pct = 10;
              if (pct > 90) pct = 90;
              appRef.current.style.setProperty('--secondary-split', `${pct}%`);
            };
            const onUp = () => {
              document.removeEventListener('mousemove', onMove);
              document.removeEventListener('mouseup', onUp);
              document.removeEventListener('touchmove', onMove);
              document.removeEventListener('touchend', onUp);
              window.dispatchEvent(new Event('resize'));
            };
            document.addEventListener('mousemove', onMove);
            document.addEventListener('mouseup', onUp);
            document.addEventListener('touchmove', onMove, { passive: false });
            document.addEventListener('touchend', onUp);
          };

          const startTimelineResize = (e) => {
            if (isTimelineExpanded || isTimelineMinimized) return;
            const tStart = e.touches ? Array.from(e.touches).at(0) : e;
            const startY = tStart.clientY;
            const startHeight = appRef.current.querySelector('.timeline-pane').offsetHeight;
            const containerHeight = appRef.current.offsetHeight;
            const onMove = (e2) => {
              const tCurrent = e2.touches ? Array.from(e2.touches).at(0) : e2;
              const currentY = tCurrent.clientY;
              const delta = currentY - startY;
              let pct = ((startHeight - delta) / containerHeight) * 100;
              if (pct < 10) pct = 10;
              if (pct > 60) pct = 60;
              appRef.current.style.setProperty('--timeline-height', `${pct}%`);
            };
            const onUp = () => {
              document.removeEventListener('mousemove', onMove);
              document.removeEventListener('mouseup', onUp);
              document.removeEventListener('touchmove', onMove);
              document.removeEventListener('touchend', onUp);
              window.dispatchEvent(new Event('resize'));
            };
            document.addEventListener('mousemove', onMove);
            document.addEventListener('mouseup', onUp);
            document.addEventListener('touchmove', onMove, { passive: false });
            document.addEventListener('touchend', onUp);
          };

          useEffect(() => {
            const gid = getOmniParam('gid') || '0';
            const bgid = getOmniParam('bgid');
            const source = getOmniParam('source') || '1kdgGiHNDsIZrn8Z1aqWXrEEYKMGxLAqFiwATx3aqbJI';
            setStatus({ text: 'Fetching CMS Manifests...', progress: 30, isFading: false, active: false });
            const fetchUrlPrimary = `https://docs.google.com/spreadsheets/d/${source}/gviz/tq?tqx=out:csv&gid=${gid}`;
            const primaryFetch = fetch(fetchUrlPrimary).then(res => res.text());
            let basemapsFetch = Promise.resolve(null);
            
            if (bgid) {
              const fetchUrlBasemaps = `https://docs.google.com/spreadsheets/d/${source}/gviz/tq?tqx=out:csv&gid=${bgid}`;
              basemapsFetch = fetch(fetchUrlBasemaps).then(res => res.text()).catch(e => {
                console.warn("Basemaps CMS Fetch Failed", e);
                return null;
              });
            }

            Promise.all([primaryFetch, basemapsFetch]).then(([csvPrimary, csvBasemaps]) => {
              setStatus({ text: 'Parsing Data...', progress: 60, isFading: false, active: false });
              
              if (csvBasemaps) {
                Papa.parse(csvBasemaps, {
                  header: true, skipEmptyLines: true, complete: (res) => {
                    const parsedBMs = res.data.map(row => {
                      const norm = {};
                      for (let k in row) norm[k.toLowerCase().trim()] = row[k];
                      const isActive = /^(true|yes)$/i.test(String(norm.active || '').trim());
                      const rawOpac = parseFloat(norm.defaultopacity);
                      return {
                        id: norm.id || "", label: norm.label || "", type: norm.type?.toLowerCase() === "overlay" ? "overlay" : "base",
                        url: norm.url || "", maxZoom: parseInt(norm.maxzoom, 10) || 19,
                        active: isActive, attrText: norm.attrtext || "", attrLink: norm.attrlink || "",
                        defaultOpacity: isNaN(rawOpac) ? 1.0 : rawOpac, format: norm.format || "xyz",
                        wmsLayer: norm.wmslayer ? decodeURIComponent(norm.wmslayer.trim()) : "default"
                      };
                    }).filter(b => b.id && b.url);

                    if (parsedBMs.length > 0) setBasemapsRegistry(prev => {
                      const merged = [...prev];
                      parsedBMs.forEach(bm => {
                        const existIdx = merged.findIndex(m => m.id === bm.id);
                        if (existIdx >= 0) merged[existIdx] = bm;
                        else merged.push(bm);
                      });
                      return merged;
                    });
                  }
                });
              }

              Papa.parse(csvPrimary, {
                header: true, skipEmptyLines: true, complete: (results) => {
                  const firstRowNorm = {};
                  const firstRow = results.data.at(0);
                  if (firstRow) {
                    for (let k in firstRow) firstRowNorm[k.toLowerCase().trim()] = firstRow[k];
                  }
                  const exactGet = (normObj, key) => { const val = normObj[key]; return val !== undefined && val !== null ? String(val).trim() : ""; };
                  
                  setAboutData({
                    title: exactGet(firstRowNorm, 'title') || 'Dataset Overview',
                    description: exactGet(firstRowNorm, 'description') || 'No project description provided.',
                    rawSource: source === '1kdgGiHNDsIZrn8Z1aqWXrEEYKMGxLAqFiwATx3aqbJI' ? 'Default Master DB' : source
                  });
                  setRawCsvRows(results.data);
                }
              });
            }).catch(err => {
              console.error("Fatal CMS Error", err);
              setStatus({ text: 'Error Loading Data', progress: 100, isFading: false, active: false });
            });
          }, []);

          useEffect(() => {
            if (rawCsvRows.length === 0) return;
            const exactGet = (normObj, key) => { const val = normObj[key]; return val !== undefined && val !== null ? String(val).trim() : ""; };
            const omniSplitRegex = /[\r\n]+|\\n/;
            let activeMode = dateEngineMode;
            
            if (activeMode === 'auto') {
              const hasEDTF = rawCsvRows.some(row => {
                const norm = {};
                for (let k in row) norm[k.toLowerCase().trim()] = row[k];
                return exactGet(norm, 'start edtf') !== '';
              });
              activeMode = hasEDTF ? 'edtf' : 'legacy';
            }
            
            const isUS = dateLocale === 'en-US';
                    const cleaned = rawCsvRows.map((row, index) => {
            const norm = {};
            for (let k in row) norm[k.toLowerCase().trim()] = row[k];
            
            const rowTitle = exactGet(norm, 'title') || 'Untitled Event';

            const parseChronoNode = (legacyStr, edtfStr) => {
                const cleanLegacy = legacyStr ? legacyStr.toString().trim() : '';
                const cleanEdtf = edtfStr ? edtfStr.toString().trim() : '';

                // 1. Primary Attempt: EDTF (ISO 8601-2)
                if ((activeMode === 'edtf' || activeMode === 'auto') && cleanEdtf) {
                    try {
                        const edtfObj = edtf(cleanEdtf);
                        if (edtfObj) {
                            return {
                                isEDTF: true,
                                obj: edtfObj,
                                min: edtfObj.min,
                                max: edtfObj.max,
                                isOpen: edtfObj.values ? edtfObj.values.some(v => v === Number.POSITIVE_INFINITY || v === Number.NEGATIVE_INFINITY) : false,
                                text: cleanEdtf
                            };
                        }
                    } catch (e) {
                        addLog(`[Chrono-Engine] Row ${index + 2} ("${rowTitle}"): EDTF syntax failure on "${cleanEdtf}". Rerouted to Legacy fallback.`, 'warning');
                    }
                }

                // 2. Fallback Attempt: Legacy DD/MM/YYYY
                if (!cleanLegacy) {
                    if (cleanEdtf) addLog(`[Chrono-Engine] Row ${index + 2} ("${rowTitle}"): No Legacy fallback found for failed EDTF. Rendering as Undated.`, 'warning');
                    return null;
                }

                const parts = cleanLegacy.split(' ');
                if (parts.length < 1) return null;

                const dateStr = parts.at(0) || '';
                const timeStr = parts.at(1) || '';
                const dParts = dateStr.split(/[/\-.]/);

                if (dParts.length < 3) {
                    let ts;
                    if (!isNaN(cleanLegacy) && cleanLegacy !== '') {
                        ts = (parseFloat(cleanLegacy) - 25569) * 86400 * 1000;
                    } else {
                        addLog(`[Chrono-Engine] Row ${index + 2} ("${rowTitle}"): Legacy parser failed on "${cleanLegacy}". Rendering as Undated.`, 'warning');
                        return null;
                    }
                    if (isNaN(ts)) {
                        addLog(`[Chrono-Engine] Row ${index + 2} ("${rowTitle}"): Legacy parser failed on "${cleanLegacy}". Rendering as Undated.`, 'warning');
                        return null;
                    }
                    return { isEDTF: false, min: ts, max: ts, date: new Date(ts), text: cleanLegacy };
                }

                const tParts = timeStr ? timeStr.split(':') : [];
                const secParts = String(tParts.at(2) || '0').split('.');

                const dYear = parseInt(dParts.at(2), 10);
                const dMonth = parseInt(dParts.at(isUS ? 0 : 1), 10) - 1;
                const dDay = parseInt(dParts.at(isUS ? 1 : 0), 10);

                const tHour = parseInt(tParts.at(0) || 0, 10);
                const tMin = parseInt(tParts.at(1) || 0, 10);
                const tSec = parseInt(secParts.at(0) || 0, 10);
                const tMs = parseInt(secParts.at(1) || 0, 10);

                const dateObj = new Date(dYear, dMonth, dDay, tHour, tMin, tSec, tMs);
                const ts = dateObj.getTime();

                if (isNaN(ts)) {
                    addLog(`[Chrono-Engine] Row ${index + 2} ("${rowTitle}"): Legacy parser failed on "${cleanLegacy}". Rendering as Undated.`, 'warning');
                    return null;
                }
                return { isEDTF: false, min: ts, max: ts, date: new Date(ts), text: cleanLegacy };
            };

            const locStr = exactGet(norm, 'location');
            if (!locStr) {
                addLog(`[Geo-Engine] Row ${index + 2} ("${rowTitle}"): No Location data provided. Operating in non-spatial mode.`, 'info');
            }

            return {
                id: index,
                title: rowTitle,
                startDate: parseChronoNode(exactGet(norm, 'start'), exactGet(norm, 'start edtf')),
                endDate: parseChronoNode(exactGet(norm, 'end'), exactGet(norm, 'end edtf')),
                description: exactGet(norm, 'description'),
                place: exactGet(norm, 'place'),
                location: locStr,
                subLabels: exactGet(norm, 'sublabels') || exactGet(norm, 'sub-labels') || exactGet(norm, 'sub labels') || '',
                priority: exactGet(norm, 'priority'),
                media: exactGet(norm, 'media') ? exactGet(norm, 'media').split(omniSplitRegex).map(m => m.trim()).filter(Boolean) : [],
                mediaCaption: exactGet(norm, 'media caption') ? exactGet(norm, 'media caption').split(omniSplitRegex).map(c => c.trim()) : [],
                mediaCredit: exactGet(norm, 'media credit') ? exactGet(norm, 'media credit').split(omniSplitRegex).map(c => c.trim()) : [],
                tags: exactGet(norm, 'tags') ? exactGet(norm, 'tags').split(',').map(t => t.trim()).filter(Boolean) : []
            };
        });

        // [REF: CHRONO-03] Narrative-First Sorting (Undated records appended sequentially to the end)
        const valid = cleaned.sort((a, b) => {
            const aValid = a.startDate && !isNaN(a.startDate.min);
            const bValid = b.startDate && !isNaN(b.startDate.min);
            if (aValid && bValid) return (a.startDate.min - b.startDate.min) || (a.id - b.id);
            if (aValid && !bValid) return -1;
            if (!aValid && bValid) return 1;
            return a.id - b.id;
        });

        setData(valid);

            const tagsMap = new Set();
            valid.forEach(d => {
              let rawTags = d.tags || [];
              let arr = [];
              (Array.isArray(rawTags) ? rawTags : [rawTags]).forEach(t => {
                if (typeof t === 'string') arr.push(...t.split(omniSplitRegex));
                else arr.push(t);
              });
              arr.map(s => String(s).trim()).filter(Boolean).forEach(t => tagsMap.add(t));
            });

            const laneCount = tagsMap.size > 0 ? tagsMap.size : 1;
            setTimelineRequiredHeight((laneCount * 24) + 40);

            if (!hasInitializedRef.current) {
              const paramSlide = getOmniParam('slide');
              const paramDate = getOmniParam('date');
              let initialIdx = 0;
              if (paramSlide && !isNaN(parseInt(paramSlide))) {
                initialIdx = Math.max(0, Math.min(valid.length - 1, parseInt(paramSlide) - 1));
              } else if (paramDate) {
                const targetTime = new Date(paramDate).getTime();
                if (!isNaN(targetTime)) {
                  let minDiff = Infinity;
                  valid.forEach((d, i) => {
                    if (d.startDate) {
                      const diff = Math.abs(d.startDate.min - targetTime);
                      if (diff < minDiff) { minDiff = diff; initialIdx = i; }
                    }
                  });
                }
              }
              setActiveIndex(initialIdx);
              hasInitializedRef.current = true;
            }

            setStatus({ text: 'Engine Ready', progress: 100, isFading: true, active: false });
            setTimeout(() => { setStatus({ text: '', progress: 100, isFading: true, active: true }); }, 500);
          }, [rawCsvRows, dateEngineMode, dateLocale]);

          const handleResultClick = (idx, qString) => {
            jumpToSlide(idx);
            setIsSearchOpen(false);
            if (qString && !searchHistory.includes(qString)) {
              const newH = [qString, ...searchHistory].slice(0, 8);
              setSearchHistory(newH);
              localStorage.setItem('tm_search_history', JSON.stringify(newH));
            }
          };

          const searchResults = executeSearch(searchQuery);
          const activeSlide = data.at(activeIndex);
          const hasMedia = activeSlide && activeSlide.media && activeSlide.media.length > 0;

          const CarTiMapperLogo = ({ context, appVersion }) => {
            const svgIcon = html`<svg xmlns="http://www.w3.org/2000/svg" viewBox="20 0 165 100" style="width: 100%; height: 100%; display: block;"><defs><filter id="dot-glow" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="1.2" result="blur" /><feMerge><feMergeNode in="blur" /><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge></filter></defs><path d="M28,38 L45,15 L180,15 L180,85 L45,85 L28,62 Z" fill="#2c3e50" stroke="#007acc" stroke-width="2.5" stroke-linejoin="round"/><g fill="#fff" opacity="0.9"><rect x="55" y="19" width="4" height="6" rx="1" /><rect x="71" y="19" width="4" height="6" rx="1" /><rect x="87" y="19" width="4" height="6" rx="1" /><rect x="103" y="19" width="4" height="6" rx="1" /><rect x="119" y="19" width="4" height="6" rx="1" /><rect x="135" y="19" width="4" height="6" rx="1" /><rect x="151" y="19" width="4" height="6" rx="1" /><rect x="167" y="19" width="4" height="6" rx="1" /><rect x="55" y="75" width="4" height="6" rx="1" /><rect x="71" y="75" width="4" height="6" rx="1" /><rect x="87" y="75" width="4" height="6" rx="1" /><rect x="103" y="75" width="4" height="6" rx="1" /><rect x="119" y="75" width="4" height="6" rx="1" /><rect x="135" y="75" width="4" height="6" rx="1" /><rect x="151" y="75" width="4" height="6" rx="1" /><rect x="167" y="75" width="4" height="6" rx="1" /></g><g transform="translate(112, 50)"><path d="M0,-28 L4,-6 L28,0 L4,6 L0,28 L-4,6 L-28,0 L-4,-6 Z" fill="#546e7a" opacity="0.8"/><g fill="#fcfcfc" font-family="Arial, sans-serif" font-size="7" font-weight="normal" text-anchor="middle"><text x="0" y="-21">N</text><text x="24" y="2.5">E</text><text x="0" y="27">S</text><text x="-24" y="2.5">W</text></g><g fill="#8be9fd" filter="url(#dot-glow)"><circle cx="12.5" cy="-21.6" r="1.2" /><circle cx="21.6" cy="-12.5" r="1.2" /><circle cx="21.6" cy="12.5" r="1.2" /><circle cx="12.5" cy="21.6" r="1.2" /><circle cx="-12.5" cy="21.6" r="1.2" /><circle cx="-21.6" cy="12.5" r="1.2" /><circle cx="-21.6" cy="-12.5" r="1.2" /><circle cx="-12.5" cy="-21.6" r="1.2" /></g><g transform="rotate(60)"><path d="M0,0 L-1,-16 L1,-16 Z" fill="#999" /><circle cx="0" cy="-20" r="2.8" fill="#007acc" /></g><g transform="rotate(270)"><path d="M0,0 L-1.2,-9 L1.2,-9 Z" fill="#999" /><circle cx="0" cy="-13" r="2.8" fill="#28a745" /></g><circle cx="0" cy="0" r="1.5" fill="#fff" /></g></svg>`;
			if (context === 'splash') return html`<div class="logo-stack-splash"><div class="splash-icon-wrapper">${svgIcon}</div><div class="splash-text">CarTiMap</div><div class="splash-version">${appVersion}</div></div>`;

			if (context === 'status') return html`<div style="display: flex; align-items: center; gap: 6px; height: 100%;"><div style="height: 16px; width: auto; display: flex; align-items: center;">${svgIcon}</div><div style="display: flex; align-items: baseline; gap: 4px;"><span style="font-size: 0.85rem; color: #444; line-height: 1;">CarTiMap</span><span style="font-size: 0.65rem; color: #888; line-height: 1;">${appVersion}</span></div></div>`;

			return html`<div style="display: flex; align-items: center; gap: 20px; margin-bottom: 25px;"><div style="width: 240px; height: auto; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">${svgIcon}</div><div style="display: flex; flex-direction: column; justify-content: center;"><h2 style="margin: 0; font-size: 2.2rem; color: #222; letter-spacing: -1px; line-height: 1;">CarTiMap</h2><div style="font-family: monospace; color: #007acc; font-size: 0.95rem; font-weight: 600; margin-top: 4px;">${appVersion}</div></div></div>`;
		};

          return html`
            <div id="tm-root" onClick=${() => setIsMenuOpen(false)}>
              <${VibeMonitor} logs=${logs} status=${status.text} isOpen=${isMonitorOpen} setIsOpen=${setIsMonitorOpen} activeSlide=${activeSlide} appVersion=${APP_VERSION} moduleVersions=${MODULE_VERSIONS} isTimelineExpanded=${isTimelineExpanded} timelineRequiredHeight=${timelineRequiredHeight} />
              
              ${!status.active ? html`
                <div class="loading-screen ${status.isFading ? 'fade-out' : ''}">
                  <${CarTiMapperLogo} context="splash" appVersion=${APP_VERSION} />
                  <div class="loading-bar-container"><div class="loading-bar-fill" style="width: ${status.progress}%;"></div></div>
                </div>
              ` : ''}

              ${data.length > 0 && status.active ? html`
                <div id="app-layout" ref=${appRef} class="${isTimelineExpanded ? 'is-expanded-timeline' : ''} ${isTimelineMinimized ? 'is-minimized-timeline' : ''}">
                  <div class="core-viewports ${maxPane ? 'max-' + maxPane : ''}">
                    <div class="visual-pane ${hasMedia ? '' : 'no-media'}">
					  <div class="map-pane">
						<${MapViewer} data=${data} activeIndex=${activeIndex} setActiveIndex=${jumpToSlide} maxAutoZoom=${maxAutoZoom} minimapOffset=${minimapOffset} setMinimapOffset=${setMinimapOffset} basemapsRegistry=${basemapsRegistry} maxPane=${maxPane} setMaxPane=${setMaxPane} polygonOpacity=${polygonOpacity} showButtonText=${showButtonText} visibleTimeBounds=${visibleTimeBounds} />
					  </div>
                      <div class="resizer-dyn-secondary" onMouseDown=${startSecondaryResize} onTouchStart=${startSecondaryResize}></div>
                      <div class="media-pane">
                        <${MediaViewer} activeSlide=${activeSlide} maxPane=${maxPane} setMaxPane=${setMaxPane} />
                      </div>
                    </div>
                    <div class="resizer-dyn-primary" onMouseDown=${startPrimaryResize} onTouchStart=${startPrimaryResize}></div>
                    <div class="content-slider-pane">
                      <${ContentSlider} data=${data} activeIndex=${activeIndex} setActiveIndex=${jumpToSlide} maxPane=${maxPane} setMaxPane=${setMaxPane} dateLocale=${dateLocale} formatSmartDate=${formatSmartDate} />
                    </div>
                  </div>

                  <div class="global-status-bar">
                    <div class="status-left" style="position: relative;">
                      <button class="${showButtonText ? 'status-btn-text' : 'status-btn'}" onClick=${(e) => { e.stopPropagation(); setIsMenuOpen(!isMenuOpen); }} title="Menu">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                        ${showButtonText ? html`<span>Menu</span>` : ''}
                      </button>
                      
                      ${isMenuOpen ? html`
                        <div style="position: absolute; bottom: calc(100% + 5px); left: 0; background: #fff; border: 1px solid rgba(128,128,128,0.2); border-radius: 6px; box-shadow: 0 4px 15px rgba(0,0,0,0.15); padding: 5px 0; min-width: 140px; z-index: 10000;" onClick=${e => e.stopPropagation()}>
                          <div style="padding: 10px 15px; cursor: pointer; border-bottom: 1px solid rgba(128,128,128,0.1); display: flex; align-items: center; gap: 8px; font-size: 0.85rem;" onClick=${(e) => { e.stopPropagation(); resetLayoutPanes(); setIsMenuOpen(false); }}>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg> Reset Layout
                          </div>
                          <div style="padding: 10px 15px; cursor: pointer; border-bottom: 1px solid rgba(128,128,128,0.1); display: flex; align-items: center; gap: 8px; font-size: 0.85rem;" onClick=${(e) => { e.stopPropagation(); setIsSettingsOpen(true); setIsMenuOpen(false); }}>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg> Settings
                          </div>
                          <div style="padding: 10px 15px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-size: 0.85rem;" onClick=${(e) => { e.stopPropagation(); setIsMonitorOpen(!isMonitorOpen); setIsMenuOpen(false); }}>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg> Telemetry
                          </div>
                        </div>
                      ` : ''}

                      ${aboutData ? html`<button class="status-btn" style="width: auto; padding: 0 4px; border: none; background: transparent; display: flex; align-items: center; justify-content: center;" onClick=${() => setIsAboutOpen(true)} title="About"><${CarTiMapperLogo} context="status" appVersion=${APP_VERSION} /></button>` : ''}
                    </div>

                    <div class="status-center">
                      <button class="${showButtonText ? 'status-btn-text' : 'status-btn'}" onClick=${() => { if(activeIndex > 0) jumpToSlide(activeIndex - 1); }} disabled=${activeIndex === 0} title="Previous">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                        ${showButtonText ? html`<span>Prev</span>` : ''}
                      </button>
                      <span class="semantic-time-span" title="Visible Time Span">${visibleTimeSpan || '...'}</span>
                      <button class="${showButtonText ? 'status-btn-text' : 'status-btn'}" onClick=${() => { if(activeIndex < data.length - 1) jumpToSlide(activeIndex + 1); }} disabled=${activeIndex === data.length - 1} title="Next">
                        ${showButtonText ? html`<span>Next</span>` : ''}
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                      </button>
                    </div>

                    <div class="status-right">
                      <button class="${showButtonText ? 'status-btn-text' : 'status-btn'}" onClick=${() => setIsSearchOpen(true)} title="Search">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                        ${showButtonText ? html`<span>Search</span>` : ''}
                      </button>
                      ${slideHistory && slideHistory.length > 0 ? html`<button class="${showButtonText ? 'status-btn-text' : 'status-btn'}" onClick=${goBack} title="Back to Previous Slide"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M 4 12 A 8 8 0 1 0 12 4"></path><polyline points="16 0 12 4 16 8"></polyline></svg>${showButtonText ? html`<span>Back</span>` : ''}</button>` : ''}
                      <span style="font-size: 0.85rem; color: #666; font-family: monospace;">${activeIndex + 1} / ${data.length}</span>
                    </div>
                  </div>

                  <div class="resizer-dyn-timeline" onMouseDown=${startTimelineResize} onTouchStart=${startTimelineResize}></div>
                  <div class="timeline-pane" style="height: ${isTimelineExpanded ? `${timelineRequiredHeight}px` : 'var(--timeline-height)'}; max-height: ${isTimelineMinimized ? '0px' : '100%'}; border-top: ${isTimelineMinimized ? 'none' : '1px solid #ccc'}; opacity: ${isTimelineMinimized ? '0' : '1'}; pointer-events: ${isTimelineMinimized ? 'none' : 'auto'}; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;">
                    <${TimelineScrubber} data=${data} activeIndex=${activeIndex} setActiveIndex=${jumpToSlide} setVisibleTimeSpan=${setVisibleTimeSpan} zoomLock=${zoomLock} setZoomLock=${setZoomLock} isTimelineExpanded=${isTimelineExpanded} setIsTimelineExpanded=${setIsTimelineExpanded} isTimelineMinimized=${isTimelineMinimized} setIsTimelineMinimized=${setIsTimelineMinimized} dateLocale=${dateLocale} timelineRequiredHeight=${timelineRequiredHeight} setVisibleTimeBounds=${setVisibleTimeBounds} />
                  </div>
                  
                  ${isTimelineMinimized ? html`
                    <button class="fab-btn" onClick=${() => setIsTimelineMinimized(false)} title="Restore Timeline">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                    </button>
                  ` : ''}
                </div>
              ` : ''}

              <div class="tm-backdrop ${isSearchOpen ? 'open' : ''}" onClick=${() => setIsSearchOpen(false)} style="z-index: 10000;"></div>
              <div id="search-modal" class="tm-modal ${isSearchOpen ? 'open' : ''}" style="display: ${isSearchOpen ? 'flex' : 'none'}; flex-direction: column;">
                <button class="modal-close" onClick=${() => setIsSearchOpen(false)} title="Close">×</button>
                <h3 style="margin-top: 0; font-size: 1.3rem; margin-bottom: 15px;">Search Dataset</h3>
                <input type="text" class="search-input" placeholder="Search events, places, dates..." value=${searchQuery} onInput=${e => setSearchQuery(e.target.value)} autoFocus />
                
                ${searchHistory.length > 0 && !searchQuery ? html`
                  <div style="margin-bottom: 15px;">
                    <div style="font-size: 0.8rem; color: #888; margin-bottom: 8px;">Recent Searches:</div>
                    <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                      ${searchHistory.map(h => html`<button style="background: #f0f0f0; border: 1px solid #ddd; padding: 4px 10px; border-radius: 12px; font-size: 0.8rem; cursor: pointer; color: #444;" onClick=${() => setSearchQuery(h)}>${h}</button>`)}
                    </div>
                  </div>
                ` : ''}

                <div style="flex-grow: 1; overflow-y: auto; border-top: 1px solid #eee;">
                  ${searchQuery && searchResults.length === 0 ? html`<div style="padding: 20px; text-align: center; color: #888;">No events found for "${searchQuery}"</div>` : ''}
                  ${searchResults.map(res => html`
                    <div class="search-result-item" onClick=${() => handleResultClick(res.id, searchQuery)}>
                      <div class="search-result-title">${res.title}</div>
                      <div class="search-result-meta">${formatSmartDate(res.startDate, res.endDate, dateLocale)} ${res.place ? ` • ${formatPlaces(res.place)}` : ''}</div>
                    </div>
                  `)}
                </div>
              </div>

              <div class="tm-backdrop ${isAboutOpen ? 'open' : ''}" onClick=${() => setIsAboutOpen(false)} style="z-index: 10000;"></div>
              <div id="about-modal" class="tm-modal ${isAboutOpen ? 'open' : ''}" style="display: ${isAboutOpen ? 'block' : 'none'};">
                <button class="modal-close" onClick=${() => setIsAboutOpen(false)} title="Close">×</button>
                <div style="margin-bottom: 25px;">
                  <h2 style="margin: 0 0 10px 0; font-size: 1.6rem;" dangerouslySetInnerHTML=${{__html: aboutData ? aboutData.title : 'Dataset Overview'}}></h2>
                  <div style="font-size: 1.05rem; line-height: 1.5; color: #333;" dangerouslySetInnerHTML=${{__html: aboutData ? aboutData.description : ''}}></div>
                  <div style="margin-top: 15px; text-align: left;">
                    <button class="status-btn-text" style="width: max-content; padding: 0 12px;" onClick=${() => { jumpToSlide(0); setIsAboutOpen(false); }}>View overview as slide</button>
                  </div>
                </div>
                <div style="padding-top: 20px; border-top: 1px solid #eee;">
                  <${CarTiMapperLogo} context="about" appVersion=${APP_VERSION} />
                </div>
              </div>

              <div class="tm-backdrop ${isSettingsOpen ? 'open' : ''}" onClick=${() => setIsSettingsOpen(false)} style="z-index: 10000;"></div>
              <div id="settings-modal" class="tm-modal ${isSettingsOpen ? 'open' : ''}" style="display: ${isSettingsOpen ? 'block' : 'none'}; max-width: 450px;">
                <button class="modal-close" onClick=${() => setIsSettingsOpen(false)} title="Close">×</button>
                <h3 style="margin-top: 0; font-size: 1.3rem; margin-bottom: 20px; color: #222;">Engine Settings</h3>
                <div style="display: flex; flex-direction: column; gap: 20px;">
                  <div>
                    <label style="font-weight: 600; display: block; margin-bottom: 8px; font-size: 0.9rem; color: #444;">Chronological Engine Mode</label>
                    <select value=${dateEngineMode} onChange=${e => { setDateEngineMode(e.target.value); localStorage.setItem('tm_date_engine_mode', e.target.value); }} style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc; font-size: 1rem;">
                      <option value="auto">Auto-Detect (Prefers EDTF)</option>
                      <option value="edtf">Strict EDTF (ISO 8601-2)</option>
                      <option value="legacy">Legacy (DD/MM or MM/DD)</option>
                    </select>
                  </div>
                  <div style="border-top: 1px solid #eee; padding-top: 15px;">
                    <label style="font-weight: 600; display: block; margin-bottom: 8px; font-size: 0.9rem; color: #444;">Interface Mode</label>
                    <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                      <input type="checkbox" checked=${showButtonText} onChange=${e => { setShowButtonText(e.target.checked); localStorage.setItem('tm_show_button_text', JSON.stringify(e.target.checked)); }} style="width: 18px; height: 18px; cursor: pointer;" />
                      <span style="font-size: 1rem; color: #333;">Show Text Labels on Buttons</span>
                    </label>
                  </div>
                  <div style="border-top: 1px solid #eee; padding-top: 15px;">
                    <label style="font-weight: 600; display: block; margin-bottom: 8px; font-size: 0.9rem; color: #444;">Legacy Date Locale Format</label>
                    <select value=${dateLocale} onChange=${e => { setDateLocale(e.target.value); localStorage.setItem('tm_date_locale', e.target.value); }} style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc; font-size: 1rem;">
                      <option value="en-GB">European (DD/MM/YYYY)</option>
                      <option value="en-US">American (MM/DD/YYYY)</option>
                      <option value="el-GR">Greek (ΗΗ/ΜΜ/ΕΕΕΕ)</option>
                    </select>
                  </div>
                  <div style="border-top: 1px solid #eee; padding-top: 15px;">
                    <label style="font-weight: 600; display: block; margin-bottom: 8px; font-size: 0.9rem; color: #444;">Map Auto-Zoom Depth</label>
                    <div style="display: flex; align-items: center; gap: 15px;">
                      <input type="range" min="5" max="20" step="1" value=${maxAutoZoom} onInput=${e => { setMaxAutoZoom(parseInt(e.target.value)); localStorage.setItem('tm_max_auto_zoom', e.target.value); }} style="flex-grow: 1; -webkit-appearance: none; height: 4px; background: #ddd; border-radius: 2px; outline: none;" />
                      <span style="font-family: monospace; font-size: 1rem; color: #007acc; font-weight: 600; width: 30px; text-align: right;">${maxAutoZoom}z</span>
                    </div>
                  </div>
                  <div style="border-top: 1px solid #eee; padding-top: 15px;">
                    <label style="font-weight: 600; display: block; margin-bottom: 8px; font-size: 0.9rem; color: #444;">Minimap Zoom Offset</label>
                    <div style="display: flex; align-items: center; gap: 15px;">
                      <input type="range" min="-8" max="0" step="1" value=${minimapOffset} onInput=${e => { setMinimapOffset(parseInt(e.target.value)); localStorage.setItem('tm_minimap_offset', e.target.value); }} style="flex-grow: 1; -webkit-appearance: none; height: 4px; background: #ddd; border-radius: 2px; outline: none;" />
                      <span style="font-family: monospace; font-size: 1rem; color: #007acc; font-weight: 600; width: 30px; text-align: right;">${minimapOffset}</span>
                    </div>
                  </div>
                  <div style="border-top: 1px solid #eee; padding-top: 15px;">
                    <label style="font-weight: 600; display: block; margin-bottom: 8px; font-size: 0.9rem; color: #444;">Global Polygon Opacity</label>
                    <div style="display: flex; align-items: center; gap: 15px;">
                      <input type="range" min="0.1" max="1" step="0.1" value=${polygonOpacity} onInput=${e => { setPolygonOpacity(parseFloat(e.target.value)); localStorage.setItem('tm_polygon_opacity', e.target.value); }} style="flex-grow: 1; -webkit-appearance: none; height: 4px; background: #ddd; border-radius: 2px; outline: none;" />
                      <span style="font-family: monospace; font-size: 1rem; color: #007acc; font-weight: 600; width: 30px; text-align: right;">${polygonOpacity.toFixed(1)}</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          `;
        };
        MODULE_VERSIONS['AppOrchestrator'] = 'v3.1.0';
        // === [ END MAJOR BLOCK ] ===
		
        // === [ MAJOR BLOCK: IgnitionSwitch v1.0.0 ] ===
        render(html`<${ErrorBoundary}><${App} /></${ErrorBoundary}>`, document.getElementById('root'));
        // === [ END MAJOR BLOCK: IgnitionSwitch v1.0.0 ] ===
    </script>
</body>
</html>
