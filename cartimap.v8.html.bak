const ContentSlider = ({data, activeIndex, setActiveIndex, maxPane, setMaxPane, dateLocale, formatSmartDate}) => {
    const touchStartX = useRef(0);
    const [isScrolled, setIsScrolled] = useState(false);
    const scrollAreaRef = useRef(null);

    const slide = data[activeIndex];

    // [REF: UX-30] State-Reset Scroll Zeroing
    useEffect(() => {
        if (scrollAreaRef.current) scrollAreaRef.current.scrollTo({ top: 0, behavior: 'auto' });
        setIsScrolled(false);
    }, [activeIndex]);

    if (!slide) return null;

    const getParsedTags = (rawTagsArray) => {
        if (!rawTagsArray || rawTagsArray.length === 0) return [];
        const splitRegex = /[\r\n]+|\\n/; let arr = [];
        (Array.isArray(rawTagsArray) ? rawTagsArray : [rawTagsArray]).forEach(t => { if (typeof t === 'string') arr.push(...t.split(splitRegex)); else arr.push(t); });
        return arr.map(s => String(s).trim()).filter(Boolean);
    };

    // [REF: CRASH-07] Bracket Immunity via .shift()
    const formatPlaces = (str) => { return str ? str.split(/[|\-·;]/).map(s => s.split(',').shift().trim()).filter(Boolean).join(' | ') : ''; };

    const tags = getParsedTags(slide.tags);
    const hasLocation = slide.place && String(slide.place).trim() !== '';

    const goPrev = () => { if (activeIndex > 0) setActiveIndex(activeIndex - 1); };
    const goNext = () => { if (activeIndex < data.length - 1) setActiveIndex(activeIndex + 1); };

    // [REF: CRASH-06] The TouchList Prototype Trap (Bracket Immunity via .item(0))
    const handleTouchStart = (e) => { 
        if(e.changedTouches && e.changedTouches.length > 0) {
            touchStartX.current = e.changedTouches.item(0).screenX; 
        }
    };
    const handleTouchEnd = (e) => {
        if(e.changedTouches && e.changedTouches.length > 0) {
            const x = e.changedTouches.item(0).screenX;
            if (touchStartX.current - x > 50) goNext();
            if (x - touchStartX.current > 50) goPrev();
        }
    };

    const handleScroll = (e) => {
        const s = e.target.scrollTop;
        if (s > 40 && !isScrolled) setIsScrolled(true);
        else if (s <= 40 && isScrolled) setIsScrolled(false);
    };

    const isDateValid = slide.startDate && !isNaN(slide.startDate.min);

    return html`
    <div class="content-pane-wrapper" style="display: flex; flex-direction: column; height: 100%; position: relative; width: 100%;">
        <div style="position: absolute; top: 15px; right: 28px; z-index: 1000;">
            <button class="status-btn ${maxPane === 'text' ? 'active' : ''}" style="background: rgba(255,255,255,0.9); border: 1px solid #ccc; box-shadow: 0 2px 5px rgba(0,0,0,0.1);" onClick=${() => setMaxPane(maxPane === 'text' ? null : 'text')} title="Toggle Maximize">
                ${maxPane === 'text'
                    ? html`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/></svg>`
                    : html`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>`
                }
            </button>
        </div>
        
        <div class="content-scroll-area" ref=${scrollAreaRef} onTouchStart=${handleTouchStart} onTouchEnd=${handleTouchEnd} onScroll=${handleScroll}>
            
            <button class="status-btn" onClick=${goPrev} disabled=${activeIndex === 0} style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); z-index: 20; background: rgba(255,255,255,0.85); width: 36px; height: 36px; border-radius: 50%; box-shadow: 0 2px 5px rgba(0,0,0,0.2); border: 1px solid #ddd; ${activeIndex === 0 ? 'display:none;' : ''}" title="Previous Slide">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button class="status-btn" onClick=${goNext} disabled=${activeIndex === data.length - 1} style="position: absolute; right: 28px; top: 50%; transform: translateY(-50%); z-index: 20; background: rgba(255,255,255,0.85); width: 36px; height: 36px; border-radius: 50%; box-shadow: 0 2px 5px rgba(0,0,0,0.2); border: 1px solid #ddd; ${activeIndex === data.length - 1 ? 'display:none;' : ''}" title="Next Slide">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>

            <div style="flex-shrink: 0; position: sticky; top: 0; background: var(--paneBg, #ffffff); z-index: 10; padding-top: ${isScrolled ? '0.6rem' : '1.2rem'}; padding-bottom: ${isScrolled ? '0.4rem' : '0.5rem'}; border-bottom: 1px solid rgba(128,128,128,0.2); box-shadow: ${isScrolled ? '0 4px 12px rgba(0,0,0,0.06)' : '0 2px 8px rgba(0,0,0,0.04)'}; display: flex; flex-direction: column; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); width: 100%; padding-left: 1.5rem; padding-right: 55px; box-sizing: border-box;">
                <div style="max-width: 85ch; width: 100%; margin: 0 auto; display: flex; flex-direction: column;">
                    <div class="metadata-ribbon" style="width: 100%; padding: 0; margin-bottom: 0.4rem; box-sizing: border-box;">
                        ${isDateValid ? html`<div class="metadata-date" style="font-weight: 600; color: #007acc; font-size: ${isScrolled ? '0.75rem' : '0.9rem'}; transition: font-size 0.2s ease; flex-shrink: 0; white-space: nowrap; margin-top: 4px;">${formatSmartDate(slide.startDate, slide.endDate, dateLocale)}</div>` : ''}
                        <div class="metadata-pills-wrapper">
                            ${hasLocation ? html`<span class="place-pill"><span style="margin-right: 4px;">📍</span> ${formatPlaces(slide.place)}</span>` : ''}
                            ${tags.map(tag => html`<span class="tag-pill"><svg width="10" height="10" viewBox="0 0 24 24" fill="rgba(255, 193, 7, 0.2)" stroke="#ffc107" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px; flex-shrink: 0;"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg><span>${tag}</span></span>`)}
                        </div>
                    </div>
                    <div class="title-header-container" style="width: 100%; padding: 0; box-sizing: border-box;">
                        <h2 style="margin: 0; font-size: ${isScrolled ? '1.1rem' : '1.4rem'}; line-height: 1.2; transition: font-size 0.3s ease; color: #222;" dangerouslySetInnerHTML=${{"__html": slide.title}}></h2>
                    </div>
                </div>
            </div>
            <div style="flex-grow: 1; padding: 0.5rem 1.5rem 2rem 1.5rem; display: flex; justify-content: center; width: 100%; box-sizing: border-box;">
                <div class="slide-desc" style="max-width: 65ch; width: 100%; margin: 0 auto;" dangerouslySetInnerHTML=${{"__html": slide.description}}></div>
            </div>
        </div>
    </div>
    `;
};
MODULE_VERSIONS['ContentSlider'] = 'v5.7.0';
